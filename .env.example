# Local development / testing only. Copy to repo root `.env`.
# Match backend keys in `backend/.env` for `uv run`. For Docker on your machine, use:
#   docker compose -f docker-compose.local.yml up --build
# Production deploy uses `docker-compose.yml` (see `docker-compose.yml.example`), not this file.

# ── Backend ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIM=1536
GEMINI_RPM=15
DATASET_ROOT=./data
MAX_ITEMS=0
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=fashion_catalog
IMAGES_DIR=./data/selected_images
AGENT_MODEL=gemini-3.1-pro-preview-customtools
VLM_MODEL=gemini-3.1-pro-preview
KAGGLE_DATASET_SLUG=silverstone1903/deep-fashion-multimodal
KAGGLE_API_TOKEN=
ADMIN_KEY=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
DATA_DIR=./backend/data
PORT=8000

# ── Docker Compose ─────────────────────────────────────────────────────────────
HTTP_PORT=80
NGROK_AUTHTOKEN=
