# Repo root `.env` — optional for local development.
# `app/backend/api.py` loads THIS file first, then `app/.env` if present, then `app/backend/.env` (backend wins last).
#
# ═══════════════════════════════════════════════════════════════════════════
# Local development (uv + Vite). Paths below must be the repo’s app/data only (or omit DATA_DIR).
#   DATA_DIR=/home/you/SecundusDermis/app/data
# ═══════════════════════════════════════════════════════════════════════════

DATA_DIR=/absolute/path/to/SecundusDermis/app/data
AUTH_DATA_DIR=/absolute/path/to/SecundusDermis/app/data

GEMINI_API_KEY=
KAGGLE_API_TOKEN=
PORT=8000

# ── Auth users (backend reads this; duplicate keys in app/backend/.env win) ──
# `file` (default) = auth_users.json  |  `notion` = Notion DB
AUTH_USERS_BACKEND=file
# NOTION_TOKEN=
# NOTION_USERS_DATABASE_ID=

# Optional: ngrok (or similar) if you tunnel the API for external tests.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Optional: override what backend uses in email links (e.g. your public tunnel URL).
FRONTEND_PUBLIC_URL=
