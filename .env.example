# Repo root `.env` — optional for local development.
# `backend/api.py` loads THIS file first, then `backend/.env` (backend wins on duplicate keys).
#
# ═══════════════════════════════════════════════════════════════════════════
# LOCAL MODE (uv + Vite)
#   Set DATA_DIR to an absolute path on the host, e.g.:
#   DATA_DIR=/home/you/SecundusDermis/backend/data
#
# DOCKER MODE (containers)
#   Configure the backend service in docker-compose.yml — not this file.
#   Typical values: DATA_DIR=/app/data , AUTH_DATA_DIR=/app/data
# ═══════════════════════════════════════════════════════════════════════════

DATA_DIR=/absolute/path/to/SecundusDermis/backend/data
AUTH_DATA_DIR=/absolute/path/to/SecundusDermis/backend/data

GEMINI_API_KEY=
KAGGLE_API_TOKEN=
PORT=8000

# ── ngrok (Docker mode) ──────────────────────────────────────────────
# `docker-compose.yml` runs an `ngrok` service automatically.
# If you set NGROK_DOMAIN, ngrok will use that fixed custom domain.
# If you leave it empty, ngrok will still start with a random domain.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Optional: override what backend uses in email links.
# If unset, docker-compose defaults to: https://${NGROK_DOMAIN} (or https://localhost).
FRONTEND_PUBLIC_URL=
