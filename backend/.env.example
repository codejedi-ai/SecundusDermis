# Copy to `.env` and fill in secrets. Never commit `.env`.
#
# ═══════════════════════════════════════════════════════════════════════════
# RUN MODE — this file is for LOCAL development (`cd backend && uv run python api.py`).
# In DOCKER mode, set the same variables in docker-compose `environment:` instead
# (typically DATA_DIR=/app/data, AUTH_DATA_DIR=/app/data; see README "Run modes").
# ═══════════════════════════════════════════════════════════════════════════
#
# ── Data layout (required for local mode) ───────────────────────────────────
# LOCAL: absolute path on your machine (recommended).
# DOCKER: not read from this file — use compose env, usually DATA_DIR=/app/data.
#
# Kaggle bundle ends up at:
#   {DATA_DIR}/kaggle/deep-fashion-multimodal.zip
# Extracted dataset root:
#   {DATA_DIR}/kaggle/deep-fashion-multimodal/
# Full absolute path on your machine (match Docker bind mount host path if you share data).
DATA_DIR=/absolute/path/to/SecundusDermis/backend/data
AUTH_DATA_DIR=/absolute/path/to/SecundusDermis/backend/data

GEMINI_API_KEY=
KAGGLE_API_TOKEN=
KAGGLE_DATASET_SLUG=silverstone1903/deep-fashion-multimodal

# Gmail (password reset / email verification)
GMAIL_USER=
GMAIL_PASSWORD=
FRONTEND_PUBLIC_URL=http://localhost:5173

PORT=8000
