# Docker run mode: DATA_DIR=/app/data inside the container.
# Use the SAME host directory as backend/.env DATA_DIR so uv and Docker share one dataset:
#   volumes:
#     - /absolute/path/to/SecundusDermis/backend/data:/app/data
# Or keep a named volume (data is separate from local uv).
# Local-only: backend/.env — see README "Run modes".
services:
  backend:
    build:
      context: ./backend
    environment:
      - GEMINI_API_KEY=your_gemini_api_key
      - GEMINI_MODEL=gemini-3.1-pro-preview-customtools
      - GEMINI_THINKING_LEVEL=low
      - KAGGLE_API_TOKEN=your_kaggle_api_token
      - DATA_DIR=/app/data
      - AUTH_DATA_DIR=/app/data
      - PORT=8000
    volumes:
      - backend-data:/app/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  frontend:
    build:
      context: ./frontend
    ports:
      - "80:80"
    depends_on:
      - backend
    restart: unless-stopped

  ngrok:
    image: ngrok/ngrok:latest
    command: sh -c 'if [ -n "$NGROK_DOMAIN" ]; then ngrok http frontend:80 --domain "$NGROK_DOMAIN"; else ngrok http frontend:80; fi'
    environment:
      - NGROK_AUTHTOKEN=your_ngrok_authtoken
      # Optional: use a fixed custom domain if you have one.
      # - NGROK_DOMAIN=your-ngrok-domain.ngrok-free.app
    depends_on:
      - frontend
    restart: unless-stopped

volumes:
  backend-data:
