# ── FastAPI backend (AI fashion search) ───────────────────────────────────
# Leave both empty in development — Vite proxies /api → localhost:8000
# and /images → localhost:8000/images automatically (see vite.config.ts).
#
# In production, point these at your deployed backend:
#   VITE_API_URL=https://your-backend.com
#   VITE_IMAGE_URL=https://your-backend.com
VITE_API_URL=
VITE_IMAGE_URL=
