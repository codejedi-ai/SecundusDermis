# Copy to ``.env`` in this directory for a **Gemini-only** agent deployment.
# Never commit ``.env``. The API server should not need these variables.

# Required — see also GOOGLE_API_KEY if your host sets that instead.
GEMINI_API_KEY=

# Optional alias (used if GEMINI_API_KEY is empty)
# GOOGLE_API_KEY=

# Optional: omit for local dev — same auto secret file as backend under ``app/data/.sd_agent_internal_secret``.
# Set in production or when ``DATA_DIR`` is not the shared ``app/data`` folder.
AGENT_INTERNAL_SECRET=

# FastAPI origin the agent calls for ``/internal/agent/*`` (default below)
# BACKEND_URL=http://127.0.0.1:8000

# Optional: Socket.IO as trusted ``agent`` — patron fan-out (``agent_emit``) + duplex ``sd_bridge``
# Either flag enables the same client connection:
# SD_SOCKETIO_EMIT=1
# SD_AGENT_SOCKET=1
# Comma-separated extra API hostnames allowed for the ``websocket`` ReAct tool (see AGENT_MANIFEST.md)
# SD_WEBSOCKET_ALLOWED_HOSTS=staging.internal,10.0.0.5
