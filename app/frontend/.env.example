# ── FastAPI (browser must reach this host for JSON + static image mounts) ──
#
# VITE_API_URL — optional for **production builds** when API is on another origin.
#   Ignored while `npm run dev` runs (API always uses /api → Vite proxy).
#
# Default local dev:
#   - API calls use /api → Vite proxies to localhost:8000
#   - Images use http://localhost:8000/images/... directly (see src/lib/api-base.ts)
#
# Optional overrides (production build / split-origin):
# VITE_API_URL=https://api.yourdomain.com     # split-origin prod only; /api is appended if missing
# Do NOT set VITE_API_URL=http://localhost:8000 for ./run.sh prod (use unset → same-origin /api).
# VITE_BACKEND_URL=http://localhost:8000     # image / upload URLs (defaults in DEV already)
# VITE_IMAGE_URL=                             # alias legacy; same role as VITE_BACKEND_URL
#
# Production build behind nginx (/api + /images proxied): leave all unset.
# Production static host without proxy: set at build time, e.g.
#   VITE_BACKEND_URL=https://api.yourdomain.com

VITE_API_URL=
VITE_BACKEND_URL=
VITE_IMAGE_URL=

# false = hide sign-in UI; stylist/cart routes open without login (match backend AUTH_ENABLED).
# VITE_AUTH_ENABLED=false
