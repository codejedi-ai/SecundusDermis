# Copy to `.env` and fill in secrets. Never commit `.env`.
#
# ═══════════════════════════════════════════════════════════════════════════
# RUN MODE — local development (`cd app/backend && uv run python api.py`).
# In production, set the same variables in your host or PaaS environment.
# (typically omit DATA_DIR — defaults to ../data → app/data — or set to that path only.)
# ═══════════════════════════════════════════════════════════════════════════
#
# ── Data (optional) ─────────────────────────────────────────────────────────
# Omit DATA_DIR and AUTH_DATA_DIR to use {repo}/app/data automatically.
# If set, both must resolve to that same folder (see app/backend/config.py).
# Kaggle bundle ends up at:
#   {DATA_DIR}/kaggle/deep-fashion-multimodal.zip
# Extracted dataset root:
#   {DATA_DIR}/kaggle/deep-fashion-multimodal/
# Full absolute path on your machine (must be the repo’s app/data directory).
# You may delete these two lines to use the default app/data automatically.
DATA_DIR=/absolute/path/to/SecundusDermis/app/data
AUTH_DATA_DIR=/absolute/path/to/SecundusDermis/app/data

# ── AI: Gemini runs only on the standalone agent (app/agent). Backend proxies patron chat to it. ──
# Required for POST /api/patron/agent/chat/stream, journal vector indexing, and RAG embeddings:
AGENT_SERVICE_URL=http://127.0.0.1:8765
# Optional: if unset, a random secret is written to ``{DATA_DIR}/.sd_agent_internal_secret``
# (same folder backend and agent use) so local dev works without duplicating this in two .env files.
# Set explicitly in production (and never commit real values).
AGENT_INTERNAL_SECRET=choose-a-long-random-string-shared-with-the-agent
# Legacy POST /api/chat, /api/chat/stream, and /api/image/upload return 410 — browsers use sdag_… on /api/patron/agent/* only.
# On the **agent** process only (see app/agent/.env or same file if you share one):
#   GEMINI_API_KEY=...
#   GEMINI_MODEL=gemini-3.1-pro-preview-customtools
#   GEMINI_THINKING_LEVEL=low

KAGGLE_API_TOKEN=
KAGGLE_DATASET_SLUG=silverstone1903/deep-fashion-multimodal

# Gmail (password reset / email verification)
GMAIL_USER=
GMAIL_PASSWORD=
FRONTEND_PUBLIC_URL=http://localhost:5173
# HTTP CORS on FastAPI: ``false`` when the browser only hits the API via Vite’s same-origin ``/api`` proxy (``./run.sh dev`` sets this). ``true`` (default) for production or when the SPA calls the API on another origin.
# CORS_ENABLED=true
# When CORS is enabled: merged with FRONTEND_PUBLIC_URL (comma-separated).
# CORS_ALLOWED_ORIGINS=https://your-spa.example
# Optional: unset in env to use default (localhost / 127.0.0.1 any port). Set to empty string to disable regex.
# CORS_ALLOW_ORIGIN_REGEX=

# ── Auth: where user accounts live (sessions/tokens still use JSON files) ──
# `file` (default) — auth_users.json under AUTH_DATA_DIR
# `notion` — Notion database; never creates pages, only PATCHes rows with empty Email
AUTH_USERS_BACKEND=file
# NOTION_TOKEN=
# NOTION_USERS_DATABASE_ID=

# HttpOnly session cookie (``sd_session_id``). Defaults: SameSite=lax, Secure off (fine for local HTTP).
# Split-origin SPA + API over HTTPS: set ``SESSION_COOKIE_SAMESITE=none`` and ``SESSION_COOKIE_SECURE=true``
# (``none`` forces Secure in code).
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE=false

PORT=8000
