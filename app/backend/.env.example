# Copy to `.env` and fill in secrets. Never commit `.env`.
#
# ═══════════════════════════════════════════════════════════════════════════
# RUN MODE — local development (`cd app/backend && uv run python api.py`).
# In production, set the same variables in your host or PaaS environment.
# (typically omit DATA_DIR — defaults to ../data → app/data — or set to that path only.)
# ═══════════════════════════════════════════════════════════════════════════
#
# ── Data (optional) ─────────────────────────────────────────────────────────
# Omit DATA_DIR and AUTH_DATA_DIR to use {repo}/app/data automatically.
# If set, both must resolve to that same folder (see app/backend/config.py).
# Kaggle bundle ends up at:
#   {DATA_DIR}/kaggle/deep-fashion-multimodal.zip
# Extracted dataset root:
#   {DATA_DIR}/kaggle/deep-fashion-multimodal/
# Full absolute path on your machine (must be the repo’s app/data directory).
# You may delete these two lines to use the default app/data automatically.
DATA_DIR=/absolute/path/to/SecundusDermis/app/data
AUTH_DATA_DIR=/absolute/path/to/SecundusDermis/app/data

GEMINI_API_KEY=
KAGGLE_API_TOKEN=
KAGGLE_DATASET_SLUG=silverstone1903/deep-fashion-multimodal

# Gmail (password reset / email verification)
GMAIL_USER=
GMAIL_PASSWORD=
FRONTEND_PUBLIC_URL=http://localhost:5173

# ── Auth: where user accounts live (sessions/tokens still use JSON files) ──
# `file` (default) — auth_users.json under AUTH_DATA_DIR
# `notion` — Notion database; never creates pages, only PATCHes rows with empty Email
AUTH_USERS_BACKEND=file
# NOTION_TOKEN=
# NOTION_USERS_DATABASE_ID=

PORT=8000
